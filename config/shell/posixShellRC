vimfiles() # {{{
{
    if [[ -z "$1" ]] || [[ "$1" = "-h" ]] || [[ "$1" = "--help" ]]; then
        echo "Open files in Vim resulting from a command"
        echo "e.g. vimfiles \"grep -rl 'hoge' dir\""
        echo "     vimfiles \"find dir -name '*.txt'\""
        return 1
    fi
    local files=()
    local cmd_res=$(eval "$1" 2>&1 | tr '\n' ' ')
    eval "local cmd_list=(${cmd_res})"
    for file in $cmd_list; do
        if [[ -f "$file" ]]; then
            echo "Open $file"
            files+=("$file")
        else
            echo "File not found: $file"
        fi
    done
    sleep 1
    if (( ${#files[@]} > 0 )); then
        vim_wrapper "${files[@]}"
    fi
}
