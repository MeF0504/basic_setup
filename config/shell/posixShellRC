add_env() # {{{
{
    local echo_usage="
    usage: add_env [-h] [-dvf] dir

    add dir/*/bin to PATH
    add dir/*/lib and dir/*/lib64 to LIBRARY_PATH & LD_LIBRARY_PATH
    add dir/*/share/man to MANPATH
    ignore directories starts with '_'

    positional arguments:
        dir    : path to the target directory

    optional arguments:
        -h, --help   show this help message and exit
        -d           also add dir/*/lib and dir/*/lib64 to DYLD_LIBRARY_PATH
        -v           show the verbose.
        -f           force add pathes (add pathes even if already exists)
    "

    local dyn=0
    local verbose=0
    local force=0
    local in_dir=''

    ## argument analysis https://qiita.com/b4b4r07/items/dcd6be0bb9c9185475bb
    # typeset -i tmpargc=0
    # typeset -a tmpargv=()
    # echo argv $argv
    # echo argc $argc
    # $argv is the default variable of zsh. don't use it as a local variable.

    if (( $# == 0 )); then
        echo "$echo_usage"
        return
    fi
    while (( $# > 0 ))
    do
        case $1 in
            -*)
                if [[ "$1" =~ 'h' ]]; then
                    echo "$echo_usage"
                    return
                fi
                if [[ "$1" =~ 'd' ]]; then
                    dyn=1
                fi
                if [[ "$1" =~ 'v' ]]; then
                    verbose=1
                fi
                if [[ "$1" =~ 'f' ]]; then
                    force=1
                fi
                shift
                ;;
            *)
                in_dir="$1"
                shift
                ;;
        esac
    done
    if [[ ${in_dir: -1:1} = '/' ]]; then
        # remove '/' at end
        in_dir=${in_dir%/}
    fi

    for basedir in $(find "$in_dir" -mindepth 1 -maxdepth 1 \( -type d -o -type l \)); do
        if [[ $verbose = 1 ]]; then echo "  @ $basedir"; fi
        local bname=
        bname="$(basename "$basedir")"
        if [ "${bname:0:1}" = "_" ]; then
            if [[ $verbose = 1 ]]; then echo 'skip'; fi
            continue
        fi
        ### bin
        if [[ $force = 1 ]]; then
            local bin_add=1
        elif [[ $PATH =~ ".*${basedir}/bin:.*" ]]; then
            local bin_add=0
        else
            local bin_add=1
        fi
        if [[ -d "${basedir}/bin" && $bin_add = 1 ]]; then
            export PATH=$basedir/bin:$PATH
            if [[ $verbose = 1 ]]; then echo "add $basedir/bin to PATH"; fi
        fi

        ### lib
        # LIBRARY_PATH is for build? LD_LIBRARY_PATH is for execute?
        if [[ $force = 1 ]]; then
            local llib_add=1
        elif [[ $LD_LIBRARY_PATH =~ ".*${basedir}/lib:.*" ]]; then
            local llib_add=0
        else
            local llib_add=1
        fi
        if [[ -d "${basedir}/lib" && $llib_add = 1 ]]; then
            export LD_LIBRARY_PATH=$basedir/lib:$LD_LIBRARY_PATH
            if [[ $verbose = 1 ]]; then echo "add $basedir/lib to LD_LIBRARY_PATH"; fi
        fi

        if [[ $force = 1 ]]; then
            local lib_add=1
        elif [[ $LIBRARY_PATH =~ ".*${basedir}/lib:.*" ]]; then
            local lib_add=0
        else
            local lib_add=1
        fi
        if [[ -d "${basedir}/lib" && $lib_add = 1 ]]; then
            export LIBRARY_PATH=$basedir/lib:$LIBRARY_PATH
            if [[ $verbose = 1 ]]; then echo "add $basedir/lib to LIBRARY_PATH"; fi
        fi

        # DYLD_LIBRARY_PATH
        if [[ $force = 1 ]]; then
            local dlib_add=1
        elif [[ $DYLD_LIBRARY_PATH =~ ".*${basedir}/lib:.*" ]]; then
            local dlib_add=0
        else
            local dlib_add=1
        fi
        if [[ "$dyn" = "1" && -d "$basedir"/lib && $dlib_add = 1 ]]; then
            export DYLD_LIBRARY_PATH=$basedir/lib:$DYLD_LIBRARY_PATH
            if [[ $verbose = 1 ]]; then echo "add $basedir/lib to DYLD_LIBRARY_PATH"; fi
        fi

        # lib64
        if [[ $force = 1 ]]; then
            local llib64_add=1
        elif [[ $LD_LIBRARY_PATH =~ ".*${basedir}/lib64:.*" ]]; then
            local llib64_add=0
        else
            local llib64_add=1
        fi
        if [[ -d "${basedir}/lib64" && $llib64_add = 1 ]]; then
            export LD_LIBRARY_PATH=$basedir/lib64:$LD_LIBRARY_PATH
            if [[ $verbose = 1 ]]; then echo "add $basedir/lib64 to LD_LIBRARY_PATH"; fi
        fi

        if [[ $force = 1 ]]; then
            local lib64_add=1
        elif [[ $LIBRARY_PATH =~ ".*${basedir}/lib64:.*" ]]; then
            local lib64_add=0
        else
            local lib64_add=1
        fi
        if [[ -d "${basedir}/lib64" && $lib64_add = 1 ]]; then
            export LIBRARY_PATH=$basedir/lib64:$LIBRARY_PATH
            if [[ $verbose = 1 ]]; then echo "add $basedir/lib64 to LIBRARY_PATH"; fi
        fi

        # DYLD_LIBRARY_PATH
        if [[ $force = 1 ]]; then
            local dlib64_add=1
        elif [[ $DYLD_LIBRARY_PATH =~ ".*${basedir}/lib64:.*" ]]; then
            local dlib64_add=0
        else
            local dlib64_add=1
        fi
        if [[ "$dyn" = "1" && -d "$basedir"/lib64 && $dlib64_add = 1 ]]; then
            export DYLD_LIBRARY_PATH=$basedir/lib64:$DYLD_LIBRARY_PATH
            if [[ $verbose = 1 ]]; then echo "add $basedir/lib64 to DYLD_LIBRARY_PATH"; fi
        fi

        ## man
        if [[ $force = 1 ]]; then
            local man_add=1
        elif [[ $MANPATH =~ ".*${basedir}/share/man:.*" ]]; then
            local man_add=0
        else
            local man_add=1
        fi
        if [[ -d "$basedir"/share/man && $man_add = 1 ]]; then
            if [[ $verbose = 1 ]]; then echo "add $basedir/share/man to MANPATH"; fi
            export MANPATH=$basedir/share/man:$MANPATH
        fi
    done
} # }}}
vim_wrapper() # {{{
{
    if [[ -n "${VIM_TERMINAL}" ]]; then
        # vimдёЉгЃ‹г‚‰shellг‚’ж“ЌдЅњгЃ—гЃ¦vimгЃ§й–‹гЃЏ
        # :h terminal-api
        fp=$(cd $(dirname $1) && pwd)/$(basename $1)
        echo -ne "\e]51;[\"call\", \"Tapi_Drop\", [\"$(pwd)\", \"$1\"]]\x07"
        return
    elif [[ -n "${NVIM}" ]]; then
        # Neovim гЃ§г‚‚гЃ§гЃЌг‚‹г‚‰гЃ—гЃ„
        # https://zenn.dev/vim_jp/articles/drop-from-terminal-neovim
        nvim -u NONE --server $NVIM --headless --remote-expr "Tapi_Drop(0, ['$(pwd)', '$1'])"
        return
    elif [[ -x $(which "$_USE_VIM" 2> /dev/null) ]]; then
        local use_vim=$_USE_VIM
    else
        local use_vim="vim"
    fi
    $use_vim -p "$@"
}
alias vi=vim_wrapper
